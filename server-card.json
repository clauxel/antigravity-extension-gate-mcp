{
  "name": "antigravityextensiongate",
  "title": "Antigravity Extension Gate",
  "description": "A paid remote MCP for Antigravity extension compatibility MCP, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://antigravityextensiongate.clauxel.com/",
  "documentationUrl": "https://antigravityextensiongate.clauxel.com/mcp/",
  "endpointUrl": "https://antigravityextensiongate.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://antigravityextensiongate.clauxel.com/api/agent-checkout",
